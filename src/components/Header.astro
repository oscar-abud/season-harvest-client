---
import Nav from "../components/Nav.astro";
import { Cart } from "./Cart";
interface Props {
  showImg?: boolean;
}

const { showImg = true } = Astro.props;
---
<div class="container">
  <Nav />
  
</div>

<header id="header">
  {showImg && (
    <img class="logo" src="/images/logo.png" alt="Logo" />
  )}
</header>

<style scoped>
  .container{
    display: flex;
    position: relative;
  }
</style>